# App
NODE_ENV=development
CLIENT_PORT=3000
SERVER_PORT=5000
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Database
DATABASE_URL=postgresql://lms_user:lms_pass@localhost:5432/lms_db?schema=public

# Auth
JWT_SECRET=replace-with-a-long-random-local-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Local uploads
# This path is resolved from lms/server when running the server workspace.
UPLOAD_DIR=uploads
MAX_VIDEO_SIZE_BYTES=2147483648
MAX_MATERIAL_SIZE_BYTES=104857600
MAX_THUMBNAIL_SIZE_BYTES=5242880
PUBLIC_UPLOAD_BASE_URL=http://localhost:5000/uploads
