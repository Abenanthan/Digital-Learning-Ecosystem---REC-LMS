# ============================================
# REC Digital Learning Ecosystem - Environment
# ============================================
# Copy this file to .env and update the values
# See also: server/.env.example and client/.env.example

# Server
PORT=5000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:password@localhost:5432/rec_lms?schema=public"
JWT_ACCESS_SECRET=change-this-to-a-random-secret-key
JWT_REFRESH_SECRET=change-this-to-another-random-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CLIENT_URL=http://localhost:3000

# Client
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_APP_NAME="REC Digital Learning Ecosystem"
